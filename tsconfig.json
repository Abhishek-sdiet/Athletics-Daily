{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": ".",
    "outDir": "dist", 
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"]
    },

    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node"],
    "moduleResolution": "node"
  },

  "include": [
    "server/**/*",
    "shared/**/*"
  ],

  "exclude": [
    "node_modules",
    "client",
    "dist",
    "vite.config.ts"
  ]
}